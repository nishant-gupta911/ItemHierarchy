<h2>Item Hierarchy Tree</h2>

@if (TempData["SuccessMessage"] != null)
{
    <div style="color: green; margin-bottom: 15px; padding: 10px; background-color: #d4edda; border: 1px solid #c3e6cb; border-radius: 4px;">
        @TempData["SuccessMessage"]
    </div>
}

<p>
    <a href="/Item" style="padding: 8px 15px; background-color: #6c757d; color: white; text-decoration: none; border-radius: 4px;">Back to Items</a>
    <a href="/Item/Process" style="padding: 8px 15px; background-color: #28a745; color: white; text-decoration: none; border-radius: 4px; margin-left: 10px;">Create Relations</a>
</p>

@{
    var treeHtml = ViewBag.TreeHtml as string;
}

@if (!string.IsNullOrEmpty(treeHtml))
{
    @Html.Raw(treeHtml)
}
else
{
    <p style="color: red;">Unable to render tree.</p>
}