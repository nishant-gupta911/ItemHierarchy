@model List<ItemProcessingSystemCore.Models.Item>

<h2>Process Item - Create Relations</h2>

@if (TempData["ErrorMessage"] != null)
{
    <div style="color: red; margin-bottom: 15px; padding: 10px; background-color: #f8d7da; border: 1px solid #f5c6cb; border-radius: 4px;">
        <p>@TempData["ErrorMessage"]</p>
    </div>
}

@if (TempData["SuccessMessage"] != null)
{
    <div style="color: green; margin-bottom: 15px; padding: 10px; background-color: #d4edda; border: 1px solid #c3e6cb; border-radius: 4px;">
        <p>@TempData["SuccessMessage"]</p>
    </div>
}

@if (Model == null)
{
    <p style="color: red;">Model is null!</p>
}
else if (Model.Count == 0)
{
    <p style="color: #ff9800; padding: 10px; background-color: #fff3cd; border-radius: 4px;">
        No items found in database. <a href="/Item/Create">Create an item first</a>.
    </p>
}
else if (Model.Count < 2)
{
    <p style="color: #ff9800; padding: 10px; background-color: #fff3cd; border-radius: 4px;">
        You need at least 2 items to create relations. <a href="/Item/Create">Create more items</a>.
    </p>
}
else
{
    <p style="color: #666; font-size: 0.9em;">Total Items: <strong>@Model.Count</strong></p>
    <p style="color: #666;">Select a parent item and one or more child items to create relationships.</p>

    <form method="post" style="max-width: 600px;">
        @Html.AntiForgeryToken()

        <div style="margin-bottom: 20px;">
            <label for="parentId" style="display: block; margin-bottom: 8px; font-weight: bold;">Parent Item:</label>
            <select name="parentId" id="parentId" style="width: 100%; padding: 8px; border: 1px solid #ddd; border-radius: 4px; font-size: 1em;">
                @foreach (var item in Model)
                {
                    <option value="@item.ItemId">@item.Name (ID: @item.ItemId, Weight: @item.Weight)</option>
                }
            </select>
            <small style="color: #666;">Choose the parent item</small>
        </div>

        <div style="margin-bottom: 20px;">
            <label style="display: block; margin-bottom: 10px; font-weight: bold;">Child Items:</label>
            <p style="color: #666; font-size: 0.9em;">Check one or more items to add as children</p>
            <div style="border: 1px solid #ddd; padding: 15px; border-radius: 4px; max-height: 250px; overflow-y: auto;">
                @foreach (var item in Model)
                {
                    <div style="margin-bottom: 10px;">
                        <input type="checkbox" name="childIds" value="@item.ItemId" id="child_@item.ItemId" />
                        <label for="child_@item.ItemId" style="display: inline; margin-left: 5px; cursor: pointer;">
                            @item.Name (ID: @item.ItemId, Weight: @item.Weight)
                        </label>
                    </div>
                }
            </div>
            <small style="color: #666;">Select at least one child item</small>
        </div>

        <div>
            <button type="submit" style="padding: 10px 20px; background-color: #28a745; color: white; border: none; border-radius: 4px; cursor: pointer; font-size: 1em;">Create Relations</button>
            <a href="/Item" style="padding: 10px 20px; background-color: #6c757d; color: white; text-decoration: none; border-radius: 4px; display: inline-block; margin-left: 10px;">Cancel</a>
            <a href="/Item/Tree" style="padding: 10px 20px; background-color: #ffc107; color: black; text-decoration: none; border-radius: 4px; display: inline-block; margin-left: 10px;">View Tree</a>
        </div>
    </form>
}